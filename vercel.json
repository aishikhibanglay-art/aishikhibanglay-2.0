{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/ai-shikhi-banglay run build",
  "outputDirectory": "artifacts/ai-shikhi-banglay/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
