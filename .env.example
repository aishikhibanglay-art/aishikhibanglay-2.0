# ─── Vercel Environment Variables ────────────────────────────────────────────
# Copy these to Vercel Dashboard → Project → Settings → Environment Variables

# Frontend (Supabase)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Server (Supabase Service Role — keep secret!)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# SSLCommerz Payment Gateway
# Sandbox credentials (for testing): STORE_ID=testbox, STORE_PASSWORD=qwerty
SSLCOMMERZ_STORE_ID=your_store_id_here
SSLCOMMERZ_STORE_PASSWORD=your_store_password_here
SSLCOMMERZ_IS_LIVE=false   # Set to "true" for production

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# App URL — your Vercel domain (for SSLCommerz redirects)
# Example: https://aishikhibanglay.vercel.app  OR your custom domain
APP_URL=https://your-vercel-domain.vercel.app
